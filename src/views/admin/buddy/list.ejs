<div class="card shadow-sm">
    <div class="card-header bg-white">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="card-title font-weight-bold">Buddy List</h3>
            <a href="/admin/buddy/create" class="btn btn-primary btn-sm">
                <i class="fas fa-plus mr-1"></i> Add New Buddy
            </a>
        </div>
    </div>

    <div class="card-body table-responsive p-0">
        <table class="table table-hover text-nowrap">
            <thead class="bg-light">
                <tr>
                    <th class="th-width-70 text-center">#</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Age</th>
                    <th>Gender</th>
                    <th>Breed</th>
                    <th class="th-width-220 text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (!buddies || buddies.length === 0) { %>
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            No buddies found.
                        </td>
                    </tr>
                <% } else { %>
                    <% buddies.forEach((b, idx) => { %>
                    <tr>
                        <td class="text-center">
                            <%= ((currentPage - 1) * 5) + idx + 1 %>
                        </td>
                        <td class="font-weight-bold text-primary"><%= b.name %></td>
                        <td>
                            <span class="badge badge-info">
                                <%= (b.category && b.category.name) ? b.category.name : 'None' %>
                            </span>
                        </td>
                        <td><%= b.age ?? 0 %> yrs</td>
                        <td>
                            <i class="fas <%= b.gender === 'male' ? 'fa-mars text-blue' : 'fa-venus text-pink' %> mr-1"></i>
                            <%= b.gender === 'male' ? 'Male' : 'Female' %>
                        </td>
                        <td><%= b.breed || '-' %></td>
                        <td class="text-center">
                            <a class="btn btn-warning btn-sm mr-1" href="/admin/buddy/edit/<%= b._id %>">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <form action="/admin/buddy/delete/<%= b._id %>" method="POST" onsubmit="return confirm('Delete this buddy?')" class="inline-form">
                                <button class="btn btn-danger btn-sm" type="submit">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div> <% if (totalPages > 1) { %>
        <div class="card-footer clearfix bg-white border-top">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted">
                        Showing page <strong><%= currentPage %></strong> of <strong><%= totalPages %></strong>
                    </small>
                </div>
                <ul class="pagination pagination-sm m-0">
                    <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/buddy/list?page=<%= currentPage - 1 %>">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>

                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                            <a class="page-link" href="/admin/buddy/list?page=<%= i %>"><%= i %></a>
                        </li>
                    <% } %>

                    <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/buddy/list?page=<%= currentPage + 1 %>">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    <% } %>
</div>